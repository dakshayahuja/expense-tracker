# Copy this to .env and fill in values
# Never commit .env to git

# Local dev: postgres via docker-compose
DATABASE_URL=postgresql://expense_user:expense_pass@localhost:5432/expense_tracker

# Production: Neon Postgres (fill after Phase 4 setup)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/expense_tracker?sslmode=require

# Production CORS — set to your actual domain in Vercel env vars (leave blank for local dev)
# ALLOWED_ORIGIN=https://expenses.yourdomain.com

# Telegram (fill in Phase 5)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
